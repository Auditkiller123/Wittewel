# Firebase configuratie
# Maak een project aan op https://console.firebase.google.com
# en kopieer de waarden uit Project Settings > Your apps > Web app

EXPO_PUBLIC_FIREBASE_API_KEY=jouw-api-key-hier
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=jouw-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=jouw-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=jouw-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456
